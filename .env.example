# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=soilguard/sensors

# Storage and Retention Configuration
MEDIA_DIR=./telemetry_data/media
SENSOR_LOGS_DIR=./telemetry_data/sensor_logs
COMPLIANCE_DIR=./telemetry_data/compliance
MEDIA_RETENTION_HOURS=48
CRITICAL_DISK_USAGE_PCT=85.0

# Camera Ingestion Configuration
CAMERA_DEVICE_INDEX=0
CAMERA_FPS=30

# Audio Monitoring Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=4096

# Actuator Pin Allocations (Raspberry Pi GPIO BCM Pins)
# Configure these to align with physical relays
HARDWARE_IRRIGATION_GPIO_PIN=17
HARDWARE_NUTRIENT_GPIO_PIN=27
HARDWARE_FAN_GPIO_PIN=22
HARDWARE_ALERT_GPIO_PIN=23
HARDWARE_ENABLE_CONTROL=false

# Regulatory Consent Settings
REGIONAL_COUNCIL=Waikato Regional Council
CONSENT_ID=CONSENT-2026-SOIL-1992

# Soil Compliance Threshold Limits
# Moisture (VWC %)
THRESHOLD_MOISTURE_MIN=15.0
THRESHOLD_MOISTURE_MAX=50.0

# Soil Temperature (C)
THRESHOLD_TEMP_MAX=35.0

# Electrical Conductivity (Salinity dS/m)
THRESHOLD_EC_MAX=2.5

# Nutrient levels (mg/kg dry soil)
THRESHOLD_NITROGEN_MAX=50.0
THRESHOLD_PHOSPHORUS_MAX=80.0
THRESHOLD_POTASSIUM_MAX=300.0

# Soil pH
THRESHOLD_PH_MIN=5.5
THRESHOLD_PH_MAX=7.5

# Logging Profiles
LOG_LEVEL=INFO
LOG_FILE=
